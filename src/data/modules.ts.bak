export interface RecentModule {
  id: number;
  title: string;
  status: 'concluido' | 'liberado';
  grade: number | null;
}

export interface DashboardData {
  studentName: string;
  email: string;
  progress: number;
  completedModules: number;
  totalModules: number;
  averageGrade: number;
  lastAccess: string;
  recentModules: RecentModule[];
}

